DEEPSEEK_API_KEY=your-deepseek-api-key
SERPER_API_KEY=your-serper-api-key
EXA_API_KEY=your-exa-api-key
TWITTERAPI_IO_KEY=your-twitterapi-io-key

# Set to "sqlite" (default) or "postgres".
FLUE_DATABASE_DRIVER=sqlite
SQLITE_DATABASE_PATH=./data/flue.db

# Official-account Posts, Topics, metrics, and heat ranking.
NEWS_DATABASE_PATH=./data/news.db

# Downloaded Exa images are archived outside the Flue runtime database.
IMAGE_RESOURCE_DIR=./data/resources
# Maximum bytes accepted for one image (default: 10 MiB).
IMAGE_MAX_BYTES=10485760

# Required only when FLUE_DATABASE_DRIVER=postgres.
# DATABASE_URL=postgresql://postgres:your-password@127.0.0.1:5432/app
# POSTGRES_PASSWORD=your-password
